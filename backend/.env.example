# ============================================================
# Team Task Manager — Backend Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Server
PORT=5000
NODE_ENV=development

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=taskmanager

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=7d

# CORS — set to your frontend URL
FRONTEND_URL=http://localhost:5173

# Cookie
COOKIE_SECURE=false   # set to true in production (HTTPS)

# Email (optional — feature is disabled if these are not set)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
EMAIL_FROM="Task Manager <your@email.com>"
